// ==UserScript==
// @name         Zampto Auto Renew (Stable Flow v3.1)
// @namespace    http://tampermonkey.net/
// @version      3.1
// @description  强制原地模式：拦截一切刷新和跳转行为，确保倒计时不重置
// @author       Gemini
// @match        https://dash.zampto.net/server?id=2574*
// @grant        none
// ==/UserScript==

(function() {
    'use strict';

    const CONFIG = {
        storageKey: 'zampto_stable_v3_1',
        btnRenewText: "Renew Server",
        renewInterval: 24 * 60 * 60 * 1000 
    };

    let data = JSON.parse(localStorage.getItem(CONFIG.storageKey)) || {
        nextRunTime: 0,
        logs: [],
        isPaused: false
    };

    let isBusy = false;

    // --- 提取时间 (增加了对 script 标签的深度过滤) ---
    function getCleanExpiryMinutes() {
        const elements = Array.from(document.querySelectorAll('p, div, span, li'));
        const target = elements.find(el => 
            el.textContent.includes('Expiry') && 
            !el.textContent.includes('function') && 
            el.innerText.length < 150
        );
        if (!target) return 0;
        const text = target.innerText || target.textContent;
        let totalMinutes = 0;
        const d = text.match(/(\d+)\s*day/);
        const h = text.match(/(\d+)\s*h/);
        const m = text.match(/(\d+)\s*m/);
        if (d) totalMinutes += parseInt(d[1]) * 1440;
        if (h) totalMinutes += parseInt(h[1]) * 60;
        if (m) totalMinutes += parseInt(m[1]);
        return totalMinutes;
    }

    function getExpiryDisplay() {
        const elements = Array.from(document.querySelectorAll('p, div, span, li'));
        const target = elements.find(el => el.textContent.includes('Expiry') && !el.textContent.includes('function') && el.innerText.length < 150);
        return target ? target.innerText.replace('Expiry (Next Renewal):', '').trim() : "读取中...";
    }

    // --- UI 构建 ---
    const style = document.createElement('style');
    style.innerHTML = `
        #kb-panel { position: fixed; bottom: 10px; right: 10px; width: 380px; background: #080808; color: #ccc; z-index: 999999; border: 1px solid #333; border-radius: 6px; padding: 10px; font-family: monospace; font-size: 12px; box-shadow: 0 -5px 20px rgba(0,0,0,0.9); }
        #kb-header { display: flex; justify-content: space-between; margin-bottom: 8px; border-bottom: 1px solid #333; padding-bottom: 5px; }
        .kb-btn { cursor: pointer; border: none; padding: 5px 10px; border-radius: 3px; font-weight: bold; margin-right: 5px; }
        .kb-btn-run { background: #198754; color: white; }
        .kb-btn-pause { background: #ffc107; color: black; }
        #kb-logs { height: 160px; overflow-y: auto; background: #000; border: 1px solid #333; margin-top: 8px; padding: 5px; }
        .log-time { color: #555; margin-right: 5px; }
        .log-step { color: #6f42c1; font-weight: bold; border-left: 3px solid #6f42c1; padding-left: 5px; display: block; margin-top: 2px;}
        .log-success { color: #198754; font-weight: bold; }
    `;
    document.head.appendChild(style);

    const panel = document.createElement('div');
    panel.id = 'kb-panel';
    panel.innerHTML = `
        <div id="kb-header"><span style="color:#6f42c1;">⚓ Zampto V3.1 (Anti-Reload)</span></div>
        <div id="kb-content">
            <div id="kb-status" style="margin-bottom:8px; padding:5px; background:#222; border-radius:3px;">载入中...</div>
            <div><button id="kb-manual" class="kb-btn kb-btn-run">重置任务</button><button id="kb-pause" class="kb-btn kb-btn-pause">暂停</button></div>
            <div id="kb-logs"></div>
        </div>
    `;
    document.body.appendChild(panel);

    const ui = {
        status: document.getElementById('kb-status'),
        logs: document.getElementById('kb-logs')
    };

    function log(msg, type = 'info') {
        const time = new Date().toLocaleTimeString('en-GB');
        data.logs.unshift({ time, msg, type });
        if (data.logs.length > 50) data.logs.pop();
        localStorage.setItem(CONFIG.storageKey, JSON.stringify(data));
        ui.logs.innerHTML = data.logs.map(l => `<div><span class="log-time">[${l.time}]</span><span class="log-${l.type}">${l.msg}</span></div>`).join('');
    }

    // --- 核心逻辑 ---
    async function executeRenew() {
        if (isBusy) return;
        isBusy = true;

        const beforeMinutes = getCleanExpiryMinutes();
        log(`📊 当前有效期: ${getExpiryDisplay()}`, "info");

        const btn = Array.from(document.querySelectorAll('button, a')).find(el => el.textContent.includes(CONFIG.btnRenewText));

        if (btn) {
            log("🖱️ 正在尝试原地点击 (已拦截跳转)...", "step");
            
            // 【核心修复】：拦截按钮的默认跳转/刷新行为
            btn.onclick = function(e) {
                e.preventDefault(); 
                e.stopPropagation();
                log("🚫 已成功拦截页面刷新行为", "info");
            };
            
            btn.click(); // 触发点击
            
            log("🚀 等待 15s 观察数据变化...", "info");
            await new Promise(r => setTimeout(r, 15000));

            const afterMinutes = getCleanExpiryMinutes();
            if (afterMinutes > beforeMinutes || afterMinutes > 2000) { 
                log(`✅ 续期成功！新时间: ${getExpiryDisplay()}`, "success");
                data.nextRunTime = Date.now() + CONFIG.renewInterval;
                localStorage.setItem(CONFIG.storageKey, JSON.stringify(data));
                isBusy = false;
            } else {
                log("⚠️ 网页未刷新但数据未更新，5分钟后重试", "warn");
                data.nextRunTime = Date.now() + (5 * 60 * 1000);
                isBusy = false;
            }
        } else {
            log("❌ 未找到按钮", "error");
            isBusy = false;
        }
    }

    function loop() {
        if (data.isPaused) { ui.status.innerHTML = "🔴 脚本已暂停"; return; }
        const now = Date.now();
        const diff = data.nextRunTime - now;

        if (diff > 0) {
            const h = Math.floor(diff / 3600000);
            const m = Math.floor((diff % 3600000) / 60000);
            const s = Math.floor((diff % 60000) / 1000);
            ui.status.innerHTML = `⏳ 倒计时: ${h}h ${m}m ${s}s | ${getExpiryDisplay()}`;
            return;
        }

        ui.status.innerHTML = "⚙️ 执行中 (禁刷新模式)...";
        executeRenew();
    }

    document.getElementById('kb-manual').onclick = () => { data.nextRunTime = 0; data.logs = []; localStorage.setItem(CONFIG.storageKey, JSON.stringify(data)); location.reload(); };
    document.getElementById('kb-pause').onclick = function() { data.isPaused = !data.isPaused; this.innerText = data.isPaused ? "恢复" : "暂停"; localStorage.setItem(CONFIG.storageKey, JSON.stringify(data)); };

    log("🤖 v3.1 原地模式启动 (已禁止自动刷新)", "info");
    setInterval(loop, 1000);
})();
